  "db_name": "MySQL",
  "query": "SELECT\n          s.nombre,\n          s.apellidos,\n          s.dni,\n          m.idMembresia,\n          m.idsocio,\n          m.tipoMembresia,\n          m.fechaInicio,\n          m.fechaVencimiento,\n          m.costo\n      FROM\n          socios s\n      INNER JOIN\n          membresias m ON s.idsocio = m.idsocio\n      WHERE\n          s.dni = ?\n      ORDER BY\n          m.fechaInicio DESC, m.idMembresia DESC\n      LIMIT 1;",
